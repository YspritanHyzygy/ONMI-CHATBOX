# Local server
NODE_ENV=development
PORT=3001
# The server binds to localhost by default. Set HOST explicitly only when you
# understand the network exposure and configure CORS_ORIGINS accordingly.
HOST=127.0.0.1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional override used by tests or custom local installations.
# GEMINI_VIDEO_WEBUI_DB_PATH=/absolute/path/to/database.json

# AI Service Providers (Optional - if not configured, users need to set up via UI)
# Model IDs verified against provider docs in July 2026.
# OpenAI Configuration
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-5.5

# Google Gemini Configuration
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=gemini-3.5-flash

# Anthropic Claude Configuration
CLAUDE_API_KEY=
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_DEFAULT_MODEL=claude-sonnet-5

# X.AI Configuration
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_DEFAULT_MODEL=grok-4.5

# Ollama Configuration (for local deployment)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3
